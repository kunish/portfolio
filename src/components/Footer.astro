---
import { SOCIAL_LINKS } from '../consts';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const currentYear = new Date().getFullYear();
const buildId = currentYear.toString(36) + Math.random().toString(36).slice(2, 6);
---

<footer class="term-footer">
  <div class="term-shell">
    <!-- column block -->
    <div class="footer-grid">
      <!-- BANNER / signature -->
      <div class="footer-block">
        <div class="rule-label">// signature</div>
        <pre class="ascii-sig" aria-hidden="true"> ┓     •
 ┛┗┓┓┏┓┃┏┓┓┏┏┓
 ┛┗┛┗┛┗┛┛  ┗┻┛</pre>
        <p class="motto">
          <span class="serif">— { lang === 'zh' ? '在终端里写诗。' : 'writing poems in a terminal.' }</span>
        </p>
      </div>

      <!-- nav -->
      <div class="footer-block">
        <div class="rule-label">// nav</div>
        <ul class="footer-list">
          <li><a href={translatePath('/')} class="footer-link"><span class="bullet">▸</span>{t('nav.home')}</a></li>
          <li><a href={translatePath('/blog')} class="footer-link"><span class="bullet">▸</span>{t('nav.blog')}</a></li>
          <li><a href={translatePath('/about')} class="footer-link"><span class="bullet">▸</span>{t('nav.about')}</a></li>
          <li><a href="/rss.xml" class="footer-link"><span class="bullet">▸</span>rss.xml</a></li>
        </ul>
      </div>

      <!-- contact -->
      <div class="footer-block">
        <div class="rule-label">// contact</div>
        <ul class="footer-list">
          <li>
            <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="footer-link">
              <span class="bullet">▸</span>github.com/kunish
            </a>
          </li>
          <li>
            <a href="mailto:kunish.butt@gmail.com" class="footer-link">
              <span class="bullet">▸</span>kunish.butt@gmail.com
            </a>
          </li>
        </ul>
      </div>

      <!-- system info -->
      <div class="footer-block">
        <div class="rule-label">// system</div>
        <dl class="sys-list">
          <div><dt>build</dt><dd>{buildId}</dd></div>
          <div><dt>stack</dt><dd>astro · tailwind</dd></div>
          <div><dt>uptime</dt><dd id="uptime">0d 00:00:00</dd></div>
          <div><dt>tz</dt><dd id="tz">UTC</dd></div>
        </dl>
      </div>
    </div>

    <!-- bottom rule -->
    <div class="footer-bottom">
      <div class="bottom-line">
        <span class="prompt">exit</span>
        <span class="dim">// © {currentYear} shikun. {t('footer.rights')}.</span>
      </div>
      <div class="bottom-line">
        <span class="dim">{t('footer.builtWith')}</span>
        <span class="cursor-thin" aria-hidden="true"></span>
      </div>
    </div>
  </div>
</footer>

<style>
  .term-footer {
    margin-top: 6rem;
    padding: 3rem 0 2rem;
    border-top: 1px solid var(--color-rule);
    background: var(--color-void);
    color: var(--color-ash);
    font-size: 0.85rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px dashed var(--color-rule);
  }
  @media (min-width: 768px)  {
    .footer-grid { grid-template-columns: repeat(2, 1fr); gap: 2.5rem; }
  }
  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: 1.4fr 1fr 1.2fr 1fr; }
  }

  .footer-block { display: flex; flex-direction: column; gap: 0.85rem; }

  .ascii-sig {
    font-family: var(--font-mono);
    color: var(--color-phosphor);
    font-size: 0.7rem;
    line-height: 1.05;
    margin: 0;
    white-space: pre;
    text-shadow: 0 0 12px rgba(126, 231, 135, 0.3);
  }

  .motto {
    color: var(--color-ash);
    font-size: 0.85rem;
    margin: 0;
  }
  .motto .serif {
    color: var(--color-amber);
  }

  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .footer-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    color: var(--color-ash);
    font-family: var(--font-mono);
    transition: color var(--duration-fast) var(--ease-out-quart);
  }
  .footer-link:hover { color: var(--color-phosphor); }
  .footer-link .bullet { color: var(--color-faint); }
  .footer-link:hover .bullet { color: var(--color-phosphor); }

  .sys-list {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-family: var(--font-mono);
  }
  .sys-list > div {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 0.5rem;
    align-items: baseline;
  }
  .sys-list dt {
    color: var(--color-amber);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.65rem;
  }
  .sys-list dd {
    margin: 0;
    color: var(--color-bone);
    font-variant-numeric: tabular-nums;
  }

  .footer-bottom {
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
  .bottom-line {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }
  .dim { color: var(--color-dim); }
</style>

<script>
  // uptime since first page hit + tz
  const startKey = 'shikun_session_start';
  let start = Number(sessionStorage.getItem(startKey));
  if (!start) {
    start = Date.now();
    sessionStorage.setItem(startKey, String(start));
  }

  const upEl = document.getElementById('uptime');
  const tzEl = document.getElementById('tz');

  if (tzEl) {
    try {
      tzEl.textContent = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
    } catch { tzEl.textContent = 'UTC'; }
  }

  function fmt(n: number, w = 2) { return String(n).padStart(w, '0'); }

  function paint() {
    if (!upEl) return;
    const elapsed = Math.floor((Date.now() - start) / 1000);
    const days = Math.floor(elapsed / 86400);
    const hh = Math.floor((elapsed % 86400) / 3600);
    const mm = Math.floor((elapsed % 3600) / 60);
    const ss = elapsed % 60;
    upEl.textContent = `${days}d ${fmt(hh)}:${fmt(mm)}:${fmt(ss)}`;
  }
  paint();
  setInterval(paint, 1000);
</script>
