---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const pathname = new URL(Astro.request.url).pathname;

const navItems = [
  { key: '~',     label: t('nav.home'),  href: translatePath('/'),      hotkey: 'h' },
  { key: 'posts', label: t('nav.blog'),  href: translatePath('/blog'),  hotkey: 'p' },
  { key: 'about', label: t('nav.about'), href: translatePath('/about'), hotkey: 'a' },
];

const isActive = (href: string) => {
  if (href === '/' || href === '/en' || href === '/en/') {
    return pathname === '/' || pathname === '/en/' || pathname === '/en';
  }
  return pathname.startsWith(href);
};
---

<header class="term-header">
  <!-- top status bar -->
  <div class="status-bar">
    <div class="term-shell">
      <div class="status-bar__row">
        <a href={translatePath('/')} class="status-bar__host" aria-label="home">
          <span class="dot" aria-hidden="true"></span>
          <span class="user">shikun</span><span class="at">@</span><span class="host">dev</span>
          <span class="path">:~$</span>
        </a>

        <nav class="status-bar__nav" aria-label="primary">
          {navItems.map((item) => (
            <a
              href={item.href}
              data-hotkey={item.hotkey}
              class:list={['nav-cmd', { 'is-active': isActive(item.href) }]}
            >
              <span class="bracket">[</span><span class="key">{item.key}</span><span class="bracket">]</span>
              <span class="label">{item.label}</span>
            </a>
          ))}
        </nav>

        <div class="status-bar__right">
          <button id="kbd-help-btn" class="help-btn" type="button" aria-label="keyboard shortcuts" aria-haspopup="dialog">[?]</button>
          <span class="clock" id="term-clock" aria-label="time">--:--</span>
          <LanguageSwitcher />
          <button
            id="mobile-menu-btn"
            class="mobile-toggle"
            aria-label="Toggle menu"
            aria-expanded="false"
          >
            <span class="bracket">[</span>
            <span class="menu-icon">≡</span>
            <span class="bracket">]</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- mobile menu -->
  <div id="mobile-menu" class="mobile-menu" hidden>
    <div class="term-shell">
      <ul class="mobile-menu__list">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['mobile-menu__link', { 'is-active': isActive(item.href) }]}
            >
              <span class="prompt-arrow"></span>
              <span class="key">{item.key}</span>
              <span class="leader">···············</span>
              <span class="label">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- keyboard shortcuts help -->
  <dialog id="kbd-help" class="kbd-help" aria-label="keyboard shortcuts">
    <div class="kbd-help__head">
      <span class="prompt">man shortcuts</span>
      <button id="kbd-help-close" class="kbd-help__close" type="button" aria-label="close">[esc]</button>
    </div>
    <dl class="kbd-help__list">
      <div><dt><kbd class="kbd">h</kbd></dt><dd>home</dd></div>
      <div><dt><kbd class="kbd">p</kbd></dt><dd>posts</dd></div>
      <div><dt><kbd class="kbd">a</kbd></dt><dd>about</dd></div>
      <div><dt><kbd class="kbd">?</kbd></dt><dd>toggle this help</dd></div>
      <div><dt><kbd class="kbd">esc</kbd></dt><dd>close</dd></div>
    </dl>
  </dialog>
</header>

<style>
  .term-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .status-bar {
    background: color-mix(in oklab, var(--color-shell) 88%, transparent);
    border-bottom: 1px solid var(--color-rule);
    font-size: 0.78rem;
  }

  .status-bar__row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 3rem;
  }

  .status-bar__host {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-bone);
    font-family: var(--font-mono);
    font-weight: 500;
    letter-spacing: -0.005em;
    white-space: nowrap;
  }
  .status-bar__host:hover { color: var(--color-bone); }
  .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--color-phosphor);
    box-shadow: 0 0 6px var(--color-phosphor);
    animation: pulse 1.6s ease-in-out infinite;
  }
  .at, .path { color: var(--color-dim); }
  .user { color: var(--color-phosphor); }
  .host { color: var(--color-amber); }

  .status-bar__nav {
    display: none;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;
  }
  @media (min-width: 768px) {
    .status-bar__nav { display: inline-flex; }
  }

  .nav-cmd {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    padding: 0.35rem 0.65rem;
    color: var(--color-ash);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }
  .nav-cmd:hover { color: var(--color-phosphor); }
  .nav-cmd .bracket { color: var(--color-faint); }
  .nav-cmd .key { color: var(--color-amber); font-weight: 500; }
  .nav-cmd .label { color: inherit; text-transform: lowercase; }
  .nav-cmd:hover .bracket,
  .nav-cmd:hover .key { color: var(--color-phosphor); }

  .nav-cmd.is-active {
    color: var(--color-phosphor);
  }
  .nav-cmd.is-active .bracket,
  .nav-cmd.is-active .key { color: var(--color-phosphor); }
  .nav-cmd.is-active::after {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--color-phosphor);
    margin-left: 0.2rem;
    align-self: center;
  }

  .status-bar__right {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-left: auto;
  }
  @media (min-width: 768px) {
    .status-bar__right { margin-left: 0; }
  }

  .clock {
    display: none;
    color: var(--color-ash);
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
  }
  @media (min-width: 1024px) { .clock { display: inline; } }

  .mobile-toggle {
    display: inline-flex;
    align-items: center;
    color: var(--color-bone);
    background: transparent;
    border: 0;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1;
    padding: 0.25rem;
  }
  @media (min-width: 768px) {
    .mobile-toggle { display: none; }
  }
  .mobile-toggle .bracket { color: var(--color-faint); }
  .mobile-toggle .menu-icon { color: var(--color-phosphor); margin: 0 0.15rem; }

  .mobile-menu {
    background: var(--color-pane);
    border-bottom: 1px solid var(--color-rule);
  }
  .mobile-menu[hidden] { display: none; }

  .mobile-menu__list {
    list-style: none;
    padding: 1rem 0;
    margin: 0;
  }
  .mobile-menu__link {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.65rem 0;
    color: var(--color-ash);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
  .mobile-menu__link:hover { color: var(--color-phosphor); }
  .mobile-menu__link .key { color: var(--color-amber); }
  .mobile-menu__link .leader {
    flex: 1;
    color: var(--color-faint);
    overflow: hidden;
    white-space: nowrap;
  }
  .mobile-menu__link.is-active { color: var(--color-phosphor); }
  .mobile-menu__link.is-active .key { color: var(--color-phosphor); }

  /* Touch: comfortable ≥44px hit areas on coarse pointers */
  @media (pointer: coarse) {
    .nav-cmd { min-height: 44px; }
    .mobile-toggle { min-width: 44px; min-height: 44px; justify-content: center; padding: 0; }
    .mobile-menu__link { min-height: 44px; align-items: center; }
    .help-btn { min-height: 44px; min-width: 44px; }
  }

  /* keyboard-help trigger + overlay */
  .help-btn {
    display: none;
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--color-ash);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    padding: 0;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }
  .help-btn:hover { color: var(--color-phosphor); }
  @media (min-width: 768px) { .help-btn { display: inline; } }

  .kbd-help {
    margin: auto;
    max-width: 22rem;
    width: calc(100% - 2rem);
    padding: 0;
    background: var(--color-pane);
    border: 1px solid var(--color-rule-hi);
    color: var(--color-bone);
    font-family: var(--font-mono);
  }
  .kbd-help::backdrop {
    background: color-mix(in srgb, var(--color-void) 72%, transparent);
    backdrop-filter: blur(2px);
  }
  .kbd-help__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--color-rule);
  }
  .kbd-help__close {
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--color-ash);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }
  .kbd-help__close:hover { color: var(--color-phosphor); }
  .kbd-help__list {
    margin: 0;
    padding: 0.85rem 1rem 1rem;
    display: grid;
    gap: 0.55rem;
    font-size: 0.85rem;
  }
  .kbd-help__list > div {
    display: grid;
    grid-template-columns: 3rem 1fr;
    align-items: center;
    gap: 0.75rem;
  }
  .kbd-help__list dt { margin: 0; }
  .kbd-help__list dd { margin: 0; color: var(--color-ash); }
</style>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    if (!menu) return;
    const isHidden = menu.hasAttribute('hidden');
    if (isHidden) menu.removeAttribute('hidden');
    else menu.setAttribute('hidden', '');
    btn.setAttribute('aria-expanded', String(isHidden));
  });

  // Live clock — UTC, terminal-flavored
  const clock = document.getElementById('term-clock');
  function tick() {
    if (!clock) return;
    const d = new Date();
    const hh = String(d.getHours()).padStart(2, '0');
    const mm = String(d.getMinutes()).padStart(2, '0');
    const ss = String(d.getSeconds()).padStart(2, '0');
    clock.textContent = `${hh}:${mm}:${ss}`;
  }
  tick();
  setInterval(tick, 1000);

  // Keyboard shortcuts + help overlay (terminal-native nav)
  const help = document.getElementById('kbd-help') as HTMLDialogElement | null;
  const helpBtn = document.getElementById('kbd-help-btn');
  const helpClose = document.getElementById('kbd-help-close');
  const toggleHelp = () => { if (help) help.open ? help.close() : help.showModal(); };
  helpBtn?.addEventListener('click', toggleHelp);
  helpClose?.addEventListener('click', () => help?.close());

  const isTyping = (el: EventTarget | null) => {
    const n = el as HTMLElement | null;
    return !!n && (n.tagName === 'INPUT' || n.tagName === 'TEXTAREA' || n.isContentEditable);
  };
  document.addEventListener('keydown', (e) => {
    if (e.metaKey || e.ctrlKey || e.altKey || isTyping(e.target)) return;
    if (e.key === '?') { e.preventDefault(); toggleHelp(); return; }
    if (help?.open) return; // dialog handles its own keys (Esc closes)
    const link = document.querySelector<HTMLAnchorElement>(`.nav-cmd[data-hotkey="${e.key}"]`);
    if (link) { e.preventDefault(); window.location.href = link.href; }
  });
</script>
