---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const pathname = new URL(Astro.request.url).pathname;

const navItems = [
  { key: '~',     label: t('nav.home'),  href: translatePath('/') },
  { key: 'posts', label: t('nav.blog'),  href: translatePath('/blog') },
  { key: 'about', label: t('nav.about'), href: translatePath('/about') },
];

const isActive = (href: string) => {
  if (href === '/' || href === '/en' || href === '/en/') {
    return pathname === '/' || pathname === '/en/' || pathname === '/en';
  }
  return pathname.startsWith(href);
};
---

<header class="term-header">
  <!-- top status bar -->
  <div class="status-bar">
    <div class="term-shell">
      <div class="status-bar__row">
        <a href={translatePath('/')} class="status-bar__host" aria-label="home">
          <span class="dot" aria-hidden="true"></span>
          <span class="user">shikun</span><span class="at">@</span><span class="host">dev</span>
          <span class="path">:~$</span>
        </a>

        <nav class="status-bar__nav" aria-label="primary">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={['nav-cmd', { 'is-active': isActive(item.href) }]}
            >
              <span class="bracket">[</span><span class="key">{item.key}</span><span class="bracket">]</span>
              <span class="label">{item.label}</span>
            </a>
          ))}
        </nav>

        <div class="status-bar__right">
          <span class="clock" id="term-clock" aria-label="time">--:--</span>
          <LanguageSwitcher />
          <button
            id="mobile-menu-btn"
            class="mobile-toggle"
            aria-label="Toggle menu"
            aria-expanded="false"
          >
            <span class="bracket">[</span>
            <span class="menu-icon">≡</span>
            <span class="bracket">]</span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- mobile menu -->
  <div id="mobile-menu" class="mobile-menu" hidden>
    <div class="term-shell">
      <ul class="mobile-menu__list">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['mobile-menu__link', { 'is-active': isActive(item.href) }]}
            >
              <span class="prompt-arrow"></span>
              <span class="key">{item.key}</span>
              <span class="leader">···············</span>
              <span class="label">{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</header>

<style>
  .term-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .status-bar {
    background: color-mix(in oklab, var(--color-shell) 88%, transparent);
    border-bottom: 1px solid var(--color-rule);
    font-size: 0.78rem;
  }

  .status-bar__row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 3rem;
  }

  .status-bar__host {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-bone);
    font-family: var(--font-mono);
    font-weight: 500;
    letter-spacing: -0.005em;
    white-space: nowrap;
  }
  .status-bar__host:hover { color: var(--color-bone); }
  .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--color-phosphor);
    box-shadow: 0 0 6px var(--color-phosphor);
    animation: pulse 1.6s ease-in-out infinite;
  }
  .at, .path { color: var(--color-dim); }
  .user { color: var(--color-phosphor); }
  .host { color: var(--color-amber); }

  .status-bar__nav {
    display: none;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;
  }
  @media (min-width: 768px) {
    .status-bar__nav { display: inline-flex; }
  }

  .nav-cmd {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    padding: 0.35rem 0.65rem;
    color: var(--color-ash);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0;
    transition: color var(--duration-fast) var(--ease-out-quart);
  }
  .nav-cmd:hover { color: var(--color-phosphor); }
  .nav-cmd .bracket { color: var(--color-faint); }
  .nav-cmd .key { color: var(--color-amber); font-weight: 500; }
  .nav-cmd .label { color: inherit; text-transform: lowercase; }
  .nav-cmd:hover .bracket,
  .nav-cmd:hover .key { color: var(--color-phosphor); }

  .nav-cmd.is-active {
    color: var(--color-phosphor);
  }
  .nav-cmd.is-active .bracket,
  .nav-cmd.is-active .key { color: var(--color-phosphor); }
  .nav-cmd.is-active::after {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--color-phosphor);
    margin-left: 0.2rem;
    align-self: center;
  }

  .status-bar__right {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-left: auto;
  }
  @media (min-width: 768px) {
    .status-bar__right { margin-left: 0; }
  }

  .clock {
    display: none;
    color: var(--color-dim);
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
  }
  @media (min-width: 1024px) { .clock { display: inline; } }

  .mobile-toggle {
    display: inline-flex;
    align-items: center;
    color: var(--color-bone);
    background: transparent;
    border: 0;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1;
    padding: 0.25rem;
  }
  @media (min-width: 768px) {
    .mobile-toggle { display: none; }
  }
  .mobile-toggle .bracket { color: var(--color-faint); }
  .mobile-toggle .menu-icon { color: var(--color-phosphor); margin: 0 0.15rem; }

  .mobile-menu {
    background: var(--color-pane);
    border-bottom: 1px solid var(--color-rule);
  }
  .mobile-menu[hidden] { display: none; }

  .mobile-menu__list {
    list-style: none;
    padding: 1rem 0;
    margin: 0;
  }
  .mobile-menu__link {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.65rem 0;
    color: var(--color-ash);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
  .mobile-menu__link:hover { color: var(--color-phosphor); }
  .mobile-menu__link .key { color: var(--color-amber); }
  .mobile-menu__link .leader {
    flex: 1;
    color: var(--color-faint);
    overflow: hidden;
    white-space: nowrap;
  }
  .mobile-menu__link.is-active { color: var(--color-phosphor); }
  .mobile-menu__link.is-active .key { color: var(--color-phosphor); }
</style>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    if (!menu) return;
    const isHidden = menu.hasAttribute('hidden');
    if (isHidden) menu.removeAttribute('hidden');
    else menu.setAttribute('hidden', '');
    btn.setAttribute('aria-expanded', String(isHidden));
  });

  // Live clock — UTC, terminal-flavored
  const clock = document.getElementById('term-clock');
  function tick() {
    if (!clock) return;
    const d = new Date();
    const hh = String(d.getHours()).padStart(2, '0');
    const mm = String(d.getMinutes()).padStart(2, '0');
    const ss = String(d.getSeconds()).padStart(2, '0');
    clock.textContent = `${hh}:${mm}:${ss}`;
  }
  tick();
  setInterval(tick, 1000);
</script>
