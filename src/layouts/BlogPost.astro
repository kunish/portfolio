---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import type { Lang } from '../i18n/ui';
import { useTranslations, useTranslatedPath } from '../i18n/utils';

type Props = CollectionEntry<'blog'>['data'] & {
  lang?: Lang;
  slug?: string;
};

const { title, description, pubDate, updatedDate, lang = 'zh', slug } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const ogImage = slug ? `/og/${slug}.png` : undefined;
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <BaseHead
      title={`${title} - ${t('site.title')}`}
      description={description}
      ogImage={ogImage}
      article={true}
      publishedTime={pubDate}
    />
  </head>
  <body>
    <Header />

    <main class="post-main">
      <!-- reader status bar (less / man style) -->
      <div class="reader-bar" aria-hidden="true">
        <div class="term-shell reader-bar__inner">
          <span class="reader-bar__left">
            <span class="prompt">less</span>
            <span class="reader-bar__file">~/posts/{slug ?? 'post'}.md</span>
          </span>
          <span class="reader-bar__right">
            <span class="reader-bar__pct" id="read-pct">0%</span>
            <span class="reader-bar__hint">[ end with q ]</span>
          </span>
        </div>
        <div class="reader-bar__progress" id="read-progress"></div>
      </div>

      <article class="post">
        <div class="term-shell">
          <!-- breadcrumb -->
          <nav class="post-crumb">
            <a href={translatePath('/')} class="post-crumb__link">~</a>
            <span class="post-crumb__sep">/</span>
            <a href={translatePath('/blog')} class="post-crumb__link">posts</a>
            <span class="post-crumb__sep">/</span>
            <span class="post-crumb__here">{slug ?? 'entry'}.md</span>
          </nav>

          <!-- meta line -->
          <div class="post-meta">
            <span class="post-meta__item">
              <span class="post-meta__key">date</span>
              <span class="post-meta__val"><FormattedDate date={pubDate} lang={lang} /></span>
            </span>
            {updatedDate && (
              <span class="post-meta__item">
                <span class="post-meta__key">updated</span>
                <span class="post-meta__val"><FormattedDate date={updatedDate} lang={lang} /></span>
              </span>
            )}
            <span class="post-meta__item">
              <span class="post-meta__key">lang</span>
              <span class="post-meta__val">{lang === 'zh' ? 'zh-CN' : 'en-US'}</span>
            </span>
          </div>

          <!-- title -->
          <header class="post-header">
            <h1 class="post-title">
              <span class="post-title__hash">#</span>
              {title}
            </h1>
            {description && (
              <p class="post-lede serif">{description}</p>
            )}
          </header>

          <!-- OG image as artwork -->
          {ogImage && (
            <figure class="post-art">
              <div class="post-art__frame">
                <img
                  width={1200}
                  height={630}
                  src={ogImage}
                  alt={title}
                  loading="eager"
                />
              </div>
              <figcaption>fig. cover · auto-generated</figcaption>
            </figure>
          )}

          <!-- content -->
          <div class="post-content prose-terminal">
            <slot />
          </div>

          <!-- back -->
          <footer class="post-footer">
            <hr class="post-rule" />
            <div class="post-footer__row">
              <a href={translatePath('/blog')} class="term-cmd term-cmd--ghost">
                <span class="prompt-arrow"></span>{t('term.return')}
              </a>
              <span class="post-footer__hint">
                <span class="kbd">q</span>
                <span class="dim">to quit reader</span>
              </span>
            </div>
            <div class="post-footer__sig">
              <span class="dim">— EOF · {slug}.md</span>
            </div>
          </footer>
        </div>
      </article>
    </main>

    <Footer />

    <style>
      .post-main { padding-bottom: 4rem; }

      /* ── reader bar ──────────────────────────────────── */
      .reader-bar {
        position: sticky;
        top: 3rem; /* below header */
        z-index: 40;
        background: var(--color-void);
        border-bottom: 1px solid var(--color-rule);
        backdrop-filter: blur(12px);
      }
      .reader-bar__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        height: 2.25rem;
        font-family: var(--font-mono);
        font-size: 0.72rem;
      }
      .reader-bar__left {
        display: inline-flex;
        gap: 0.55rem;
        align-items: center;
        color: var(--color-bone);
      }
      .reader-bar__file { color: var(--color-amber); }
      .reader-bar__right {
        display: inline-flex;
        gap: 0.85rem;
        align-items: center;
        color: var(--color-dim);
      }
      .reader-bar__pct {
        color: var(--color-phosphor);
        font-variant-numeric: tabular-nums;
      }
      .reader-bar__hint {
        display: none;
      }
      @media (min-width: 768px) { .reader-bar__hint { display: inline; } }
      .reader-bar__progress {
        height: 1px;
        background: var(--color-phosphor);
        width: 0%;
        transition: width 100ms linear;
      }

      /* ── crumbs / meta ───────────────────────────────── */
      .post { padding-top: 2rem; }
      @media (min-width: 768px) { .post { padding-top: 2.75rem; } }

      .post-crumb {
        display: flex;
        gap: 0.4rem;
        align-items: center;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--color-dim);
        margin-bottom: 1.5rem;
      }
      .post-crumb__link { color: var(--color-ash); }
      .post-crumb__link:hover { color: var(--color-phosphor); }
      .post-crumb__sep { color: var(--color-faint); }
      .post-crumb__here { color: var(--color-phosphor); }

      .post-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 1.25rem;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px dashed var(--color-rule);
        font-family: var(--font-mono);
        font-size: 0.75rem;
      }
      .post-meta__item {
        display: inline-flex;
        gap: 0.4rem;
        align-items: baseline;
      }
      .post-meta__key {
        color: var(--color-amber);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.68rem;
      }
      .post-meta__val { color: var(--color-bone); }

      /* ── title ───────────────────────────────────────── */
      .post-header { margin: 0 auto 2rem; max-width: 50rem; }
      .post-title {
        font-family: var(--font-display);
        font-size: clamp(1.75rem, 4.5vw, 2.75rem);
        line-height: 1.15;
        letter-spacing: -0.025em;
        margin: 0;
        color: var(--color-bone);
        font-weight: 600;
        display: flex;
        gap: 0.5rem;
        align-items: baseline;
      }
      .post-title__hash { color: var(--color-phosphor); flex-shrink: 0; }
      .post-lede {
        margin: 1rem 0 0;
        color: var(--color-amber);
        font-size: 1.1rem;
        line-height: 1.6;
      }

      /* ── art ─────────────────────────────────────────── */
      .post-art {
        margin: 2.5rem auto;
        max-width: 50rem;
      }
      .post-art__frame {
        position: relative;
        border: 1px solid var(--color-rule-hi);
        background: var(--color-void);
        padding: 2rem 0.5rem 0.5rem;
      }
      .post-art__frame::before {
        content: "● ● ●";
        position: absolute;
        top: 0.65rem;
        left: 0.85rem;
        color: var(--color-rule-hi);
        font-size: 0.6rem;
        letter-spacing: 0.4em;
      }
      .post-art__frame::after {
        content: "cover.png";
        position: absolute;
        top: 0.45rem;
        right: 0.85rem;
        color: var(--color-faint);
        font-family: var(--font-mono);
        font-size: 0.65rem;
      }
      .post-art img {
        width: 100%;
        height: auto;
        display: block;
        opacity: 0.95;
      }
      .post-art figcaption {
        margin-top: 0.6rem;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--color-dim);
        text-align: center;
      }

      /* ── content ─────────────────────────────────────── */
      .post-content {
        max-width: 50rem;
        margin: 0 auto;
      }

      /* ── footer ──────────────────────────────────────── */
      .post-footer {
        max-width: 50rem;
        margin: 3rem auto 0;
      }
      .post-rule {
        border: 0;
        text-align: center;
        margin: 0 0 2rem;
        color: var(--color-rule-hi);
      }
      .post-rule::before {
        content: "─── EOF ───────────────────────────────────────────────────";
        color: var(--color-rule-hi);
        font-family: var(--font-mono);
        letter-spacing: 0;
      }
      .post-footer__row {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }
      .post-footer__hint {
        display: inline-flex;
        gap: 0.4rem;
        align-items: center;
        font-size: 0.78rem;
      }
      .post-footer__hint .dim { color: var(--color-dim); }
      .post-footer__sig {
        margin-top: 1.25rem;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        text-align: center;
      }
      .post-footer__sig .dim { color: var(--color-faint); }
    </style>

    <script>
      // reading progress + percentage
      const pctEl = document.getElementById('read-pct');
      const progEl = document.getElementById('read-progress');
      const article = document.querySelector('.post-content');

      function update() {
        if (!article || !pctEl || !progEl) return;
        const rect = article.getBoundingClientRect();
        const start = window.scrollY + rect.top;
        const total = rect.height - window.innerHeight + 200;
        const traveled = window.scrollY - start + 200;
        const pct = Math.max(0, Math.min(100, Math.round((traveled / total) * 100)));
        pctEl.textContent = `${pct}%`;
        (progEl as HTMLElement).style.width = `${pct}%`;
      }

      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
      update();

      // q to quit (return to blog index)
      document.addEventListener('keydown', (e) => {
        if (e.key === 'q' && !e.metaKey && !e.ctrlKey && !e.altKey) {
          const target = e.target as HTMLElement | null;
          if (target && (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.isContentEditable)) return;
          const back = document.querySelector<HTMLAnchorElement>('.post-footer .term-cmd');
          if (back) window.location.href = back.href;
        }
      });
    </script>
  </body>
</html>
