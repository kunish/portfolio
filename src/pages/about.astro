---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { PERSONAL_INFO, SKILLS, SOCIAL_LINKS } from '../consts';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const skillCategoryEN: Record<string, string> = {
  '前端框架': 'frameworks',
  '语言': 'languages',
  '工具': 'tooling',
  '其他': 'other',
};

const story = lang === 'zh'
  ? [
      '一名专注于用户体验的前端工程师，热衷于用代码雕刻界面、用结构表达想法。',
      '过去几年里参与了不同规模的项目，从初创产品到企业级应用，习惯把复杂业务拆解为优雅的技术方案。',
      '业余时间写技术博客、做开源、读散文与设计书；相信好工具与好文档同样重要。',
      '当不在写代码时，可能在看书、徒步、或者尝一杯新的咖啡。',
    ]
  : [
      'a frontend engineer focused on user experience — sculpting interfaces with code, expressing ideas through structure.',
      "for several years now i've shipped projects from scrappy startup MVPs to large-scale enterprise apps; my habit is to decompose business complexity into elegant technical solutions.",
      'on the side i write technical essays, contribute to open source, and read prose and design books. good tools and good docs are equally important to me.',
      "when i'm not coding, you'll find me reading, hiking, or trying a new coffee shop.",
    ];
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <BaseHead
      title={`${t('about.title')} - ${t('site.title')}`}
      description={t('about.description1')}
    />
  </head>
  <body>
    <Header />

    <main class="about-main">
      <div class="term-shell">
        <!-- breadcrumb -->
        <div class="rule-label about-crumb">
          <span>~</span>
          <span style="opacity:0.5;">/</span>
          <span style="color: var(--color-phosphor);">about.man</span>
          <span class="about-crumb__hint" aria-hidden="true">manual page · sec 1</span>
        </div>

        <!-- man banner -->
        <div class="manbanner">
          <span class="manbanner__left">SHIKUN(1)</span>
          <span class="manbanner__center">User Commands</span>
          <span class="manbanner__right">SHIKUN(1)</span>
        </div>

        <!-- NAME ─────────────────────────────────────────── -->
        <section class="man-section">
          <h2 class="man-h">NAME</h2>
          <p class="man-body">
            <strong>shikun</strong> — {lang === 'zh' ? '前端工程师，长期驻扎北京' : 'frontend engineer, long-term resident of Beijing'}
          </p>
        </section>

        <!-- SYNOPSIS ─────────────────────────────────────── -->
        <section class="man-section">
          <h2 class="man-h">SYNOPSIS</h2>
          <pre class="syn-block"><span class="prompt">shikun</span> <span class="syn-flag">--craft</span> <span class="syn-arg">&lt;web&gt;</span> [<span class="syn-flag">--with</span> <span class="syn-arg">react|vue|astro</span>] [<span class="syn-flag">--obsessed-with</span> <span class="syn-arg">DX</span>]</pre>
        </section>

        <!-- DESCRIPTION ──────────────────────────────────── -->
        <section class="man-section about-grid">
          <div>
            <h2 class="man-h">DESCRIPTION</h2>
          </div>
          <div class="about-prose">
            {story.map((p) => <p>{p}</p>)}
            <p class="about-pull serif">
              { lang === 'zh'
                ? '"代码不是终点，结构与体验才是。"'
                : '"code isn\'t the destination — structure and experience are."' }
            </p>
          </div>
        </section>

        <!-- VITALS — like /etc/passwd or whois ────────────── -->
        <section class="man-section">
          <h2 class="man-h">VITALS</h2>
          <div class="vitals">
            <div class="man-row"><span class="man-row__key">name</span><span class="man-row__val">{PERSONAL_INFO.name}</span></div>
            <div class="man-row"><span class="man-row__key">role</span><span class="man-row__val">{lang === 'zh' ? PERSONAL_INFO.role : 'Frontend Engineer'}</span></div>
            <div class="man-row"><span class="man-row__key">location</span><span class="man-row__val">{lang === 'zh' ? PERSONAL_INFO.location : 'Beijing, CN'}</span></div>
            <div class="man-row"><span class="man-row__key">email</span><span class="man-row__val"><a href={`mailto:${PERSONAL_INFO.email}`} class="link-reveal">{PERSONAL_INFO.email}</a></span></div>
            <div class="man-row"><span class="man-row__key">github</span><span class="man-row__val"><a href={SOCIAL_LINKS.github} target="_blank" rel="noopener" class="link-reveal">github.com/kunish</a></span></div>
            <div class="man-row"><span class="man-row__key">status</span><span class="man-row__val"><span class="heartbeat" style="vertical-align: 0.05em;"></span> {t('hero.available')}</span></div>
          </div>
        </section>

        <!-- SKILLS ──────────────────────────────────────── -->
        <section class="man-section">
          <h2 class="man-h">SKILLS</h2>
          <div class="skills-grid">
            {SKILLS.map((skill, i) => (
              <article class="skill-card">
                <div class="skill-card__head">
                  <span class="skill-card__num">$ {String(i).padStart(2, '0')}</span>
                  <h3 class="skill-card__title">
                    {lang === 'zh' ? skill.category : (skillCategoryEN[skill.category] ?? skill.category)}
                  </h3>
                </div>
                <ul class="skill-card__list">
                  {skill.items.map((item, idx) => (
                    <li>
                      <span class="bullet">{String(idx + 1).padStart(2, '0')}.</span>
                      <span class="name">{item}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </section>

        <!-- CONTACT ─────────────────────────────────────── -->
        <section class="man-section">
          <h2 class="man-h">CONTACT</h2>
          <div class="contact-card">
            <div class="contact-card__head">
              <span class="prompt">contact --interactive</span>
            </div>
            <p class="contact-card__lede serif">{t('about.contactDescription')}</p>
            <div class="contact-card__actions">
              <a href={`mailto:${PERSONAL_INFO.email}`} class="term-cmd term-cmd--rose">mail</a>
              <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener" class="term-cmd term-cmd--ghost">github →</a>
            </div>
          </div>
        </section>

        <!-- man footer -->
        <div class="manbanner manbanner--bottom">
          <span class="manbanner__left">shikun.dev</span>
          <span class="manbanner__center">2026 · BJ</span>
          <span class="manbanner__right">SHIKUN(1)</span>
        </div>
      </div>
    </main>

    <Footer />

    <style>
      .about-main { padding: 3rem 0 5rem; }
      @media (min-width: 768px) { .about-main { padding: 4rem 0 6rem; } }

      .about-crumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
      }
      .about-crumb__hint {
        margin-left: auto;
        color: var(--color-faint);
        font-size: 0.65rem;
      }

      /* ── manpage banner row ───────────────────────────── */
      .manbanner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 0;
        margin: 1.5rem 0 2.5rem;
        border-top: 1px solid var(--color-rule-hi);
        border-bottom: 1px solid var(--color-rule-hi);
        font-family: var(--font-display);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--color-ash);
      }
      .manbanner__center { color: var(--color-phosphor); }
      .manbanner--bottom { margin: 4rem 0 0; }

      /* ── sections ─────────────────────────────────────── */
      .man-section {
        margin-bottom: 3rem;
      }
      .man-h {
        font-family: var(--font-display);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--color-amber);
        padding-bottom: 0.5rem;
        margin-bottom: 1rem;
        border-bottom: 1px dashed var(--color-rule);
      }
      .man-body {
        margin: 0;
        font-size: 1rem;
        line-height: 1.8;
      }
      .man-body strong {
        color: var(--color-phosphor);
        font-weight: 600;
      }

      .syn-block {
        font-family: var(--font-mono);
        font-size: 0.95rem;
        background: var(--color-pane);
        border: 1px solid var(--color-rule);
        padding: 1rem 1.25rem;
        margin: 0;
        overflow-x: auto;
        color: var(--color-bone);
      }
      .syn-flag { color: var(--color-amber); }
      .syn-arg  { color: var(--color-cyan); }

      /* ── DESCRIPTION grid ─────────────────────────────── */
      .about-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }
      @media (min-width: 1024px) {
        .about-grid {
          grid-template-columns: 14rem 1fr;
          gap: 3rem;
          align-items: start;
        }
        .about-grid > div:first-child { position: sticky; top: 5rem; }
      }
      .about-prose p {
        margin: 0 0 1rem;
        font-size: 1rem;
        line-height: 1.85;
        color: var(--color-bone);
      }
      .about-pull {
        padding: 1rem 1.25rem;
        border-left: 2px solid var(--color-phosphor);
        background: rgba(126, 231, 135, 0.05);
        font-size: 1.1rem;
        line-height: 1.5;
        color: var(--color-amber);
        margin-top: 1.25rem;
      }

      /* ── vitals ───────────────────────────────────────── */
      .vitals {
        border: 1px solid var(--color-rule);
        background: var(--color-pane);
        padding: 1.25rem 1.5rem;
      }
      .vitals .man-row {
        grid-template-columns: 6rem 1fr;
        padding: 0.5rem 0;
        border-bottom: 1px dashed var(--color-rule);
      }
      .vitals .man-row:last-child { border-bottom: 0; }

      /* ── skills ───────────────────────────────────────── */
      .skills-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.85rem;
      }
      @media (min-width: 640px)  { .skills-grid { grid-template-columns: repeat(2, 1fr); } }
      @media (min-width: 1024px) { .skills-grid { grid-template-columns: repeat(4, 1fr); } }

      .skill-card {
        padding: 1.25rem;
        border: 1px solid var(--color-rule);
        background: var(--color-pane);
        transition: all var(--duration-base) var(--ease-out-quart);
      }
      .skill-card:hover {
        border-color: var(--color-phosphor);
      }
      .skill-card__head {
        display: flex;
        align-items: baseline;
        gap: 0.6rem;
        padding-bottom: 0.6rem;
        border-bottom: 1px dashed var(--color-rule);
        margin-bottom: 0.85rem;
      }
      .skill-card__num {
        color: var(--color-phosphor);
        font-family: var(--font-display);
        font-size: 0.78rem;
      }
      .skill-card__title {
        font-family: var(--font-display);
        font-size: 1rem;
        margin: 0;
        text-transform: lowercase;
        letter-spacing: 0;
      }
      .skill-card__list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 0.4rem;
        font-size: 0.85rem;
      }
      .skill-card__list li {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        color: var(--color-bone);
        font-family: var(--font-mono);
      }
      .skill-card__list .bullet {
        color: var(--color-faint);
        font-variant-numeric: tabular-nums;
      }

      /* ── contact ──────────────────────────────────────── */
      .contact-card {
        padding: 2rem 1.5rem;
        border: 1px solid var(--color-rule-hi);
        background: var(--color-pane);
      }
      @media (min-width: 768px) { .contact-card { padding: 2.5rem; } }
      .contact-card__head {
        margin-bottom: 1rem;
        padding-bottom: 0.85rem;
        border-bottom: 1px dashed var(--color-rule);
      }
      .contact-card__lede {
        color: var(--color-ash);
        font-size: 1.1rem;
        margin: 0 0 1.5rem;
      }
      .contact-card__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
      }
    </style>
  </body>
</html>
