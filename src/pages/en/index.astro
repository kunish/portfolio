---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../i18n/utils';
import { PERSONAL_INFO, SKILLS, SOCIAL_LINKS } from '../../consts';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => (post.data.lang || 'zh') === lang)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const totalEntries = allPosts.length;
const firstYear = Math.min(...allPosts.map((p) => p.data.pubDate.getFullYear()));
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <BaseHead title={t('site.title')} description={t('site.description')} />
  </head>
  <body>
    <Header />

    <main>
      <!-- ═════════════════ Hero / boot sequence ═════════════════ -->
      <section class="hero">
        <div class="term-shell">
          <!-- breadcrumb -->
          <div class="rule-label" style="margin-bottom: 1.25rem;">
            <span>~</span>
            <span style="opacity:0.5;">/</span>
            <span style="color: var(--color-phosphor);">index.html</span>
          </div>

          <div class="hero__grid">
            <!-- left: boot lines + headline -->
            <div class="hero__main">
              <div class="boot stagger">
                <p class="type-line boot-line">
                  <span class="prompt">whoami</span>
                </p>
                <p class="type-line boot-line">
                  <span class="boot-out">{t('term.whoami')}</span>
                </p>
                <p class="type-line boot-line">
                  <span class="prompt">cat headline.md</span>
                </p>
              </div>

              <h1 class="hero__title type-line stagger" style="animation-delay: 700ms;">
                <span class="hero__line">{t('hero.title.line1')}</span>
                <span class="hero__line hero__line--accent">{t('hero.title.line2')}</span>
                <span class="hero__line">{t('hero.title.line3')}<span class="cursor-thin"></span></span>
              </h1>

              <p class="hero__lede type-line" style="animation-delay: 920ms;">
                <span class="prompt-arrow"></span>{t('hero.description')}
              </p>

              <div class="hero__cta type-line" style="animation-delay: 1080ms;">
                <a href={translatePath('/blog')} class="term-cmd">cd posts</a>
                <a href={translatePath('/about')} class="term-cmd term-cmd--ghost">cat about.md</a>
                <a href={`mailto:${PERSONAL_INFO.email}`} class="term-cmd term-cmd--ghost">mail</a>
              </div>
            </div>

            <!-- right: terminal panel -->
            <aside class="hero__panel ascii-frame" data-label="profile.json">
              <div class="panel-row">
                <span class="panel-key">user</span>
                <span class="panel-val">"{PERSONAL_INFO.name}"</span>
              </div>
              <div class="panel-row">
                <span class="panel-key">role</span>
                <span class="panel-val">"{lang === 'zh' ? PERSONAL_INFO.role : 'frontend engineer'}"</span>
              </div>
              <div class="panel-row">
                <span class="panel-key">loc</span>
                <span class="panel-val">"{lang === 'zh' ? PERSONAL_INFO.location : 'Beijing, CN'}"</span>
              </div>
              <div class="panel-row">
                <span class="panel-key">focus</span>
                <span class="panel-val">"{t('hero.focusValue')}"</span>
              </div>
              <div class="panel-row">
                <span class="panel-key">posts</span>
                <span class="panel-val">"{totalEntries} entries · since {firstYear}"</span>
              </div>
              <div class="panel-row panel-row--status">
                <span class="panel-key">status</span>
                <span class="panel-status">
                  <span class="heartbeat" aria-hidden="true"></span>
                  {t('hero.available')}
                </span>
              </div>

              <div class="panel-divider">─── stack ─────────────────</div>

              <ul class="panel-tags">
                {SKILLS[0].items.slice(0, 4).map((s) => (
                  <li><span class="chip chip--phosphor">{s}</span></li>
                ))}
                {SKILLS[1].items.slice(0, 2).map((s) => (
                  <li><span class="chip">{s}</span></li>
                ))}
              </ul>

              <div class="panel-meta">
                <span class="prompt-arrow"></span>
                <span class="dim">last post:</span>
                <span class="amber">{posts.length ? <FormattedDate date={posts[0].data.pubDate} lang={lang} /> : '—'}</span>
              </div>
            </aside>
          </div>
        </div>
      </section>

      <!-- ═════════════════ Stack / ls ./tools ═════════════════ -->
      <section class="stack-block">
        <div class="term-shell">
          <div class="section-title">
            <span class="section-title__hash">##</span>
            <h2 class="section-title__text">{t('term.stack')}</h2>
            <span class="section-title__meta">$ ls ./tools</span>
          </div>

          <div class="stack-grid">
            {SKILLS.map((skill, i) => (
              <article class="stack-card">
                <header class="stack-card__head">
                  <span class="stack-card__num">[{String(i).padStart(2, '0')}]</span>
                  <h3 class="stack-card__title">
                    {lang === 'zh' ? skill.category : (
                      skill.category === '前端框架' ? 'frameworks' :
                      skill.category === '语言' ? 'languages' :
                      skill.category === '工具' ? 'tooling' : 'other'
                    )}
                  </h3>
                </header>
                <ul class="stack-card__list">
                  {skill.items.map((item) => (
                    <li class="stack-card__item">
                      <span class="bullet">▸</span>
                      <span class="name">{item}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- ═════════════════ Recent posts / git log ═════════════════ -->
      <section class="posts-block">
        <div class="term-shell">
          <div class="section-title">
            <span class="section-title__hash">##</span>
            <h2 class="section-title__text">{t('term.recent')}</h2>
            <span class="section-title__meta">$ git log --oneline | head -5</span>
          </div>

          {posts.length === 0 ? (
            <p class="posts-empty">{t('term.empty')}</p>
          ) : (
            <ol class="post-log">
              {posts.map((post, i) => (
                <li>
                  <a href={`${translatePath('/blog')}/${post.id}/`} class="log-row">
                    <span class="log-row__index">{String(i + 1).padStart(2, '0')}</span>
                    <span class="log-line">
                      <span class="log-row__title">{post.data.title}</span>
                      <span class="leader" aria-hidden="true">·····················································································</span>
                      <span class="log-row__desc">{post.data.description}</span>
                    </span>
                    <span class="log-row__meta">
                      <FormattedDate date={post.data.pubDate} lang={lang} />
                    </span>
                  </a>
                </li>
              ))}
            </ol>
          )}

          <div class="posts-footer">
            <a href={translatePath('/blog')} class="term-cmd term-cmd--ghost">ls -la /posts</a>
          </div>
        </div>
      </section>

      <!-- ═════════════════ CTA / mail ═════════════════ -->
      <section class="cta-block">
        <div class="term-shell">
          <div class="cta">
            <div class="cta__top">
              <span class="prompt">mail -s "hello"</span>
              <span class="cta__addr">{PERSONAL_INFO.email}</span>
            </div>
            <h2 class="cta__title">
              {t('cta.title')}
              <span class="cursor-thin" aria-hidden="true"></span>
            </h2>
            <p class="cta__desc serif">{t('cta.description')}</p>
            <div class="cta__actions">
              <a href={`mailto:${PERSONAL_INFO.email}`} class="term-cmd term-cmd--rose">{t('cta.button')}</a>
              <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="term-cmd term-cmd--ghost">open github</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer />

    <style>
      /* ─── Hero ─────────────────────────────────────────────────── */
      .hero { padding: 3rem 0 5rem; }
      @media (min-width: 768px) { .hero { padding: 4rem 0 7rem; } }

      .hero__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
      }
      @media (min-width: 1024px) {
        .hero__grid {
          grid-template-columns: 1.6fr 1fr;
          gap: 4rem;
          align-items: start;
        }
      }

      .boot {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--color-ash);
        margin-bottom: 1.75rem;
      }
      .boot-line { margin: 0; padding: 0.1rem 0; }
      .boot-out { color: var(--color-bone); padding-left: 0.85rem; }
      .boot-out::before {
        content: "›";
        color: var(--color-phosphor);
        margin-right: 0.45rem;
        margin-left: -0.85rem;
      }

      .hero__title {
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 9vw, 6rem);
        font-weight: 600;
        line-height: 0.96;
        letter-spacing: -0.04em;
        margin: 0 0 1.5rem;
        display: block;
      }
      .hero__line {
        display: block;
        text-wrap: balance;
        overflow-wrap: break-word;
      }
      .hero__line--accent { color: var(--color-phosphor); }

      .hero__lede {
        margin: 1.75rem 0 2rem;
        max-width: 36rem;
        color: var(--color-ash);
        font-size: 1rem;
        line-height: 1.75;
      }
      .hero__lede .prompt-arrow { color: var(--color-phosphor); margin-right: 0.4rem; }

      .hero__cta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
      }

      /* ─── Hero panel ───────────────────────────────────────────── */
      .hero__panel {
        margin-top: 1rem;
        font-size: 0.85rem;
      }
      @media (min-width: 1024px) {
        .hero__panel { position: sticky; top: 5rem; margin-top: 3.5rem; }
      }
      .panel-row {
        display: grid;
        grid-template-columns: 4.5rem 1fr;
        gap: 0.75rem;
        padding: 0.4rem 0;
        align-items: baseline;
      }
      .panel-key {
        color: var(--color-amber);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .panel-val {
        color: var(--color-bone);
        font-family: var(--font-mono);
      }
      .panel-row--status { padding-top: 0.6rem; border-top: 1px dashed var(--color-rule); margin-top: 0.6rem; }
      .panel-status {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--color-phosphor);
        font-size: 0.78rem;
      }
      .panel-divider {
        margin: 1rem 0 0.65rem;
        font-size: 0.7rem;
        color: var(--color-faint);
        letter-spacing: 0;
      }
      .panel-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        list-style: none;
        margin: 0 0 1rem;
        padding: 0;
      }
      .panel-meta {
        display: inline-flex;
        gap: 0.4rem;
        align-items: baseline;
        margin-top: 0.5rem;
        font-size: 0.72rem;
      }
      .panel-meta .dim { color: var(--color-ash); }
      .panel-meta .amber { color: var(--color-amber); }
      .panel-meta .prompt-arrow::before { color: var(--color-phosphor); }


      /* ─── Stack ────────────────────────────────────────────────── */
      .stack-block { padding: 5rem 0; }
      .stack-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }
      @media (min-width: 640px)  { .stack-grid { grid-template-columns: repeat(2, 1fr); } }
      @media (min-width: 1024px) { .stack-grid { grid-template-columns: repeat(4, 1fr); } }

      .stack-card {
        padding: 1.25rem;
        border: 1px solid var(--color-rule);
        background: var(--color-pane);
        transition: all var(--duration-base) var(--ease-out-quart);
      }
      .stack-card:hover {
        border-color: var(--color-phosphor);
        background: color-mix(in oklab, var(--color-pane) 80%, var(--color-phosphor) 4%);
      }
      .stack-card__head {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        padding-bottom: 0.6rem;
        border-bottom: 1px dashed var(--color-rule);
        margin-bottom: 0.85rem;
      }
      .stack-card__num {
        color: var(--color-phosphor);
        font-family: var(--font-display);
        font-size: 0.78rem;
      }
      .stack-card__title {
        font-family: var(--font-display);
        font-size: 1rem;
        margin: 0;
        text-transform: lowercase;
        letter-spacing: 0;
      }
      .stack-card__list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 0.35rem;
        font-size: 0.85rem;
      }
      .stack-card__item {
        display: flex;
        align-items: baseline;
        gap: 0.4rem;
        color: var(--color-ash);
        font-family: var(--font-mono);
      }
      .stack-card__item .bullet { color: var(--color-faint); }

      /* ─── Posts ────────────────────────────────────────────────── */
      .posts-block {
        padding: 5rem 0;
        border-top: 1px solid var(--color-rule);
      }
      .post-log {
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .post-log .log-row {
        cursor: pointer;
      }
      .log-line {
        display: flex;
        align-items: baseline;
        gap: 0.6rem;
        min-width: 0;
        overflow: hidden;
      }
      .log-row__title {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 40%;
      }
      .log-row__desc {
        color: var(--color-ash);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 0.8rem;
        flex: 1;
      }
      @media (max-width: 640px) {
        .log-row {
          grid-template-columns: auto 1fr;
          align-items: start;
        }
        .log-row__index { grid-row: 1 / span 2; }
        .log-line { flex-direction: column; align-items: flex-start; gap: 0.2rem; }
        .leader { display: none; }
        .log-row__title, .log-row__desc { max-width: 100%; white-space: normal; }
        .log-row__meta { text-align: left; font-size: 0.7rem; }
      }

      .posts-empty {
        text-align: center;
        padding: 3rem 0;
        color: var(--color-ash);
      }
      .posts-footer {
        margin-top: 2rem;
        display: flex;
        justify-content: flex-end;
      }

      /* ─── CTA ──────────────────────────────────────────────────── */
      .cta-block { padding: 5rem 0; }
      .cta {
        position: relative;
        padding: 2.5rem 1.5rem;
        border: 1px solid var(--color-phosphor);
        background: linear-gradient(
          135deg,
          color-mix(in srgb, var(--color-phosphor) 4%, transparent) 0%,
          color-mix(in srgb, var(--color-rose) 4%, transparent) 100%
        );
      }
      @media (min-width: 768px) {
        .cta { padding: 3.5rem 3rem; }
      }
      .cta::before, .cta::after {
        content: "";
        position: absolute;
        width: 18px; height: 18px;
        border: 2px solid var(--color-phosphor);
      }
      .cta::before { top: -2px; left: -2px; border-right: 0; border-bottom: 0; }
      .cta::after  { bottom: -2px; right: -2px; border-left: 0; border-top: 0; }

      .cta__top {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: baseline;
        margin-bottom: 1rem;
        font-size: 0.8rem;
      }
      .cta__addr { color: var(--color-amber); }

      .cta__title {
        font-family: var(--font-display);
        font-size: clamp(1.75rem, 5vw, 3rem);
        font-weight: 600;
        line-height: 1.05;
        letter-spacing: -0.025em;
        margin: 0 0 1rem;
      }
      .cta__desc {
        color: var(--color-ash);
        font-size: 1.05rem;
        margin: 0 0 1.75rem;
        max-width: 38rem;
      }
      .cta__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
      }
    </style>
  </body>
</html>
